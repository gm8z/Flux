	-- CreateTab: adds a sidebar icon tab + scrolling page
	function Win:CreateTab(name, iconId)
		local Tab=Instance.new("TextButton") Tab.Size=UDim2.new(0,TabSize,0,TabSize)
		Tab.BackgroundTransparency=1 Tab.Text="" Tab.AutoButtonColor=false Tab.Parent=SidebarScroll

