		Prog.BackgroundColor3=C.Text Prog.BorderSizePixel=0 Prog.Parent=BarBG MakeCorner(Prog,BarH)
		local PG=Instance.new("UIGradient")
		PG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,C.GradTop),ColorSequenceKeypoint.new(1,C.GradBot)})
		PG.Parent=Prog
		local Knob=Instance.new("Frame") Knob.Size=UDim2.new(0,KS,0,KS)
		Knob.Position=UDim2.new(0,-(KS/2),0.5,-(KS/2)) Knob.BackgroundColor3=C.Text
		Knob.BorderSizePixel=0 Knob.ZIndex=2 Knob.Parent=BarBG MakeCorner(Knob,KS)

		local Value=default local Dragging=false local TargetP=(default-min)/(max-min)
		local mC,eC,rC
		local Obj={}
		local UpdateSlider, StopDrag, StartDrag

		UpdateSlider=function(pct,animated)
			pct=math.clamp(pct,0,1) Value=math.floor(min+(max-min)*pct)
			if animated then
				TweenService:Create(Prog,TweenInfo.new(0.25,Enum.EasingStyle.Quint),{Size=UDim2.new(pct,0,1,0)}):Play()
				TweenService:Create(Knob,TweenInfo.new(0.25,Enum.EasingStyle.Quint),{Position=UDim2.new(pct,-(KS/2),0.5,-(KS/2))}):Play()
			else
				Prog.Size=UDim2.new(pct,0,1,0) Knob.Position=UDim2.new(pct,-(KS/2),0.5,-(KS/2))
			end
			ValLbl.Text=tostring(Value)
			if cb then task.spawn(function() pcall(cb,Value) end) end
		end
		StopDrag=function()
			if not Dragging then return end Dragging=false
			if mC then mC:Disconnect() mC=nil end if eC then eC:Disconnect() eC=nil end
			if rC then rC:Disconnect() rC=nil end UpdateSlider(TargetP,true)
		end
		local function GetRelX(px) return (px-BarBG.AbsolutePosition.X)/BarBG.AbsoluteSize.X end
		StartDrag=function()
			if mC then mC:Disconnect() mC=nil end if eC then eC:Disconnect() eC=nil end
			if rC then rC:Disconnect() rC=nil end Dragging=true
			mC=UserInputService.InputChanged:Connect(function(i)
				if not Dragging then return end
				if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
					TargetP=math.clamp(GetRelX(i.Position.X),0,1)
				end
			end)
			eC=UserInputService.InputEnded:Connect(function(i)
				if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
					if Dragging then StopDrag() end
				end
			end)
			rC=RunService.RenderStepped:Connect(function()
				if not Dragging then StopDrag() return end
				if not BarBG or not BarBG.Parent then StopDrag() return end
				local cur=Prog.Size.X.Scale local sm=cur+(TargetP-cur)*0.08
				if math.abs(sm-TargetP)<0.008 then sm=TargetP end UpdateSlider(sm)
			end)
		end
		BarBG.InputBegan:Connect(function(i)
			if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
				TargetP=math.clamp(GetRelX(i.Position.X),0,1) StartDrag()
			end
		end)
		Knob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then StartDrag() end end)
		ResetBtn.Activated:Connect(function()
			ResetBtn.ImageColor3=C.Accent TargetP=(default-min)/(max-min) UpdateSlider(TargetP,true)
			task.delay(0.35,function() ResetBtn.ImageColor3=Color3.fromRGB(160,160,170) end)
		end)
		ResetBtn.MouseEnter:Connect(function()
			ResetBtn.ImageColor3=Color3.fromRGB(200,200,210)
			TweenService:Create(ResetBtn,TweenInfo.new(0.25,Enum.EasingStyle.Quad),{Rotation=180}):Play()
		end)
		ResetBtn.MouseLeave:Connect(function()
			ResetBtn.ImageColor3=Color3.fromRGB(160,160,170)
			TweenService:Create(ResetBtn,TweenInfo.new(0.25,Enum.EasingStyle.Quad),{Rotation=0}):Play()
		end)
		Slider.MouseEnter:Connect(function() T(Slider,0.12,{BackgroundColor3=C.ElemHov}) end)
		Slider.MouseLeave:Connect(function() T(Slider,0.12,{BackgroundColor3=C.Elem}) end)
		Slider.AncestryChanged:Connect(function() if not Slider.Parent then StopDrag() end end)
		UpdateSlider((default-min)/(max-min))
		Obj.SetValue=function(v) TargetP=(v-min)/(max-min) UpdateSlider(TargetP,true) end
		Obj.GetValue=function() return Value end
		Obj.Frame=Slider
		return Obj
	end

