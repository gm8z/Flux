		Icon.Size=UDim2.new(0,20,0,20) Icon.Image=iconId or ""
		Icon.ImageColor3=C.TextMuted Icon.Parent=BG

		local Page=Instance.new("ScrollingFrame") Page.BackgroundTransparency=1
		Page.Size=UDim2.new(1,0,1,0) Page.CanvasSize=UDim2.new(0,0,0,0)
		Page.ScrollBarThickness=IsMobile and 0 or 2 Page.ScrollBarImageColor3=C.Accent
		Page.Visible=false Page.BorderSizePixel=0 Page.Parent=PagesFolder
		local PL=Instance.new("UIListLayout") PL.Padding=UDim.new(0,14) PL.Parent=Page
		PL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			Page.CanvasSize=UDim2.new(0,0,0,PL.AbsoluteContentSize.Y+10)
		end)

		local td={Button=Tab, Background=BG, Accent=Acc, Icon=Icon, Page=Page}
		Tab.Activated:Connect(function() SelectTab(td) end)

		-- insert BEFORE the settings tab (which is always last)
		table.insert(Tabs, #Tabs, td)

		-- auto-select first real tab
		local realCount=0
		for _,t in ipairs(Tabs) do if t~=SettingsTabData then realCount+=1 end end
		if realCount==1 then SelectTab(td) end

		local TabObj={}
		function TabObj:CreateSection(sectionName)
			return MakeSectionObj(_Section(Page, sectionName))
		end
		return TabObj
	end

	-- GetSettingsTab: lets callers add sections to the built-in settings page
	function Win:GetSettingsTab()
		local ST={}
		function ST:CreateSection(sectionName)
			return MakeSectionObj(_Section(SettingsPage, sectionName))
		end
		return ST
	end

