-- ─── tiny helpers ────────────────────────────────────────────────────────────
local function MakeCorner(parent, r)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, r)
	c.Parent = parent
	return c
end
local function MakeStroke(parent, col, thick, trans)
	local s = Instance.new("UIStroke")
	s.Color        = col   or Color3.fromRGB(35,35,35)
	s.Thickness    = thick or 1.2
	s.Transparency = trans or 0.4
	s.Parent       = parent
	return s
end
local function T(obj, t, props)
	TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props):Play()
end

-- ─── safe file ops ───────────────────────────────────────────────────────────
local function SafeIsfolder(p)    local ok,r=pcall(function() return isfolder and isfolder(p) end) return ok and r==true end
local function SafeMakefolder(p)  pcall(function() if makefolder then makefolder(p) end end) end
local function SafeListfiles(p)   local ok,r=pcall(function() return listfiles and listfiles(p) or {} end) return (ok and type(r)=="table") and r or {} end
local function SafeWritefile(p,d) local ok=pcall(function() if writefile then writefile(p,d) end end) return ok end
local function SafeReadfile(p)    local ok,r=pcall(function() return readfile and readfile(p) end) return (ok and r) and r or nil end
local function SafeDelfile(p)     local ok=pcall(function() if delfile then delfile(p) end end) return ok end

