	-- ── Config system internals ──────────────────────────────────────────────
	local ConfigGather = {}   -- {fn(data)} called on save
	local ConfigApply  = {}   -- {fn(data)} called on load

	local function GatherConfig()
		local data = { _DragSpeed=DragSpeed, _CurrentKey=CurrentKey }
		for _,fn in ipairs(ConfigGather) do pcall(fn,data) end
		return data
	end
	local function ApplyConfig(data)
		if data._DragSpeed then DragSpeed=data._DragSpeed end
		if data._CurrentKey then
			CurrentKey=data._CurrentKey
			if KeybindButton then pcall(function() KeybindButton.Text=CurrentKey end) end
		end
		for _,fn in ipairs(ConfigApply) do pcall(fn,data) end
	end

	local function EnsureFolder() if not SafeIsfolder(ConfigFolder) then SafeMakefolder(ConfigFolder) end end
	local function GetConfigs()
		EnsureFolder()
		local list={}
		for _,file in ipairs(SafeListfiles(ConfigFolder)) do
			if file:sub(-#CONFIG_EXT)==CONFIG_EXT then
				local n=file:gsub(ConfigFolder.."\\",""):gsub(ConfigFolder.."/",""):gsub(CONFIG_EXT,"")
				table.insert(list,n)
			end
		end
		return list
	end

