	local Tabs       = {}
	local CurrentTab = nil
	local DragSpeed  = 0.08

	local function SelectTab(td)
		for _, v in pairs(Tabs) do
			local sel = (v == td)
			v.Page.Visible = sel
			if v.Background then T(v.Background, 0.15, {BackgroundTransparency = sel and 0.15 or 1}) end
			if v.Accent     then v.Accent.Visible = sel end
			if v.Icon       then T(v.Icon, 0.15, {ImageColor3 = sel and C.Accent or C.TextMuted}) end
		end
		CurrentTab = td
	end

