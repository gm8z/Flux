-- ============================================================
--  SORT INDEX SETUP
--  Pinned emotes keep their fixed position in newestfirst.
--  All other sort modes sort normally ignoring pins.
-- ============================================================

-- newestfirst: pinned emotes lock to their slot, rest fill gaps
do
	local pinnedPositions = {}
	for pos, _ in pairs(PinnedEmotes) do pinnedPositions[pos] = true end

	local unpinnedSorted = {}
	for _, v in ipairs(Emotes) do
		if not v.pinned then table.insert(unpinnedSorted, v) end
	end
	-- unpinned stay in their current fetch order (newest first)

	local unpinnedIdx = 1
	for i = 1, #Emotes do
		local emote = Emotes[i]
		if emote.pinned then
			emote.sort.newestfirst = i
		else
			emote.sort.newestfirst = i
		end
	end
	-- simpler: just use table index as newestfirst order
	for i, v in ipairs(Emotes) do v.sort.newestfirst = i end
end

