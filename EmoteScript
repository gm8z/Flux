local function FetchAllPages(searchParams)
	local function getFirstPage()
		local ok, page = pcall(function() return AvatarEditorService:SearchCatalog(searchParams) end)
		if not ok then task.wait(5) return getFirstPage() end
		return page
	end
	local catalogPage = getFirstPage()
	while true do
		for _, emote in pairs(catalogPage:GetCurrentPage()) do
			AddEmote(emote.Name, emote.Id, emote.Price)
		end
		if catalogPage.IsFinished then break end
		local function advance()
			if not pcall(function() catalogPage:AdvanceToNextPageAsync() end) then
				task.wait(5) advance()
			end
		end
		advance()
	end
end

