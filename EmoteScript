-- ============================================================
--  PIN SYSTEM
--  Use PinEmote(name, id, position) to lock an emote to a
--  specific slot number. Everything else fills in around it.
--
--  Example:
--    PinEmote("Floss Dance", 5917459365, 1)   -- always slot 1
--    PinEmote("Arm Wave",    5915773155, 2)   -- always slot 2
--    PinEmote("Shuffle",     4349242221, 5)   -- always slot 5
--
--  You can pin as many as you want. Gaps between pins are
--  filled automatically by the rest of the catalog emotes.
-- ============================================================

local PinnedEmotes = {} -- { position = { name, id } }

local function PinEmote(name, id, position)
	if not (name and id and position) then return end
	PinnedEmotes[position] = { name = name, id = id }
	-- also register the id so catalog fetch skips it (no duplicate)
	AddedIds[id] = true
end

local function AddEmote(name, id, price)
	if not (name and id) then return end
	if AddedIds[id] then return end
	AddedIds[id] = true
	table.insert(Emotes, {
		["name"]  = name,
		["id"]    = id,
		["icon"]  = "rbxthumb://type=Asset&id="..id.."&w=150&h=150",
		["price"] = price or 0,
		["pinned"] = false,
		["sort"]  = {}
	})
end

-- Called after all catalog fetches are done.
-- Inserts pinned emotes at their chosen positions,
-- shifting everything else down automatically.
local function ApplyPins()
	-- collect all pinned positions sorted lowest first
	local pins = {}
	for pos, data in pairs(PinnedEmotes) do
		table.insert(pins, { pos = pos, name = data.name, id = data.id })
	end
	table.sort(pins, function(a, b) return a.pos < b.pos end)

	for _, pin in ipairs(pins) do
		local entry = {
			["name"]   = pin.name,
			["id"]     = pin.id,
			["icon"]   = "rbxthumb://type=Asset&id="..pin.id.."&w=150&h=150",
			["price"]  = 0,
			["pinned"] = true,
			["sort"]   = {}
		}
		-- clamp position to valid range
		local insertAt = math.clamp(pin.pos, 1, #Emotes + 1)
		table.insert(Emotes, insertAt, entry)
	end

	-- re-index after inserting
	for i, v in ipairs(Emotes) do
		v.index = i
	end
end

